# Inoreader OAuth client
INOREADER_CLIENT_ID=your_client_id_here
INOREADER_CLIENT_SECRET=your_client_secret_here
INOREADER_REDIRECT_URI=https://YOURUSER.github.io/REPO_NAME/callback.html
INOREADER_SCOPE=read

# Filled in after you complete the auth flow once
INOREADER_ACCESS_TOKEN=your_access_token_here
INOREADER_REFRESH_TOKEN=your_refresh_token_here

# Local paths for exports/output
INO_RAW_EXPORT_DIR=exported_from_ino
INO_OUTPUT_DIR=output
# Optional if you ever host the per-tag XMLs:
# INO_TAG_BASE_URL=https://example.com/feeds/ino-tags
